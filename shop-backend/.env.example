# 服务器配置
SERVER_PORT=8081

# 数据库配置
DB_HOST=mysql
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_NAME=goshopadmin

# Redis配置
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
ENABLE_BLOOM_FILTER=true

# JWT配置
JWT_SECRET=your-secret-key
JWT_EXPIRE_HOUR=24

# RabbitMQ配置
MQ_HOST=rabbitmq
MQ_PORT=5672
MQ_USER=guest
MQ_PASSWORD=guest
MQ_VHOST=/